# ── Backend env (Render → Service → Environment) ──
# Copy to server/.env for local dev. NEVER commit real secrets.

NODE_ENV=production
# PORT is injected automatically by Render. Locally it defaults to 5000.
# PORT=5000

# Frontend origin(s) allowed by CORS — your Vercel URL.
# Comma-separate to allow several (production + preview).
FRONTEND_URL=https://owlytics.vercel.app

# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App secrets / integrations
QR_ENCRYPTION_KEY=any-long-random-string

# Cloudinary (image uploads) — optional, leave blank if unused
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (notifications) — optional, leave blank if unused
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
