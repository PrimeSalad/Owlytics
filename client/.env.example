# ── Frontend env (Vercel → Project → Settings → Environment Variables) ──
# Copy to .env.local for local dev. All client vars MUST start with VITE_.

# Backend API base URL — your Render service + "/api"
VITE_API_URL=https://owlytics-api.onrender.com/api

# Socket.IO server URL — your Render service (no /api)
VITE_SOCKET_URL=https://owlytics-api.onrender.com

# Supabase (anon/public key — safe to expose in the browser)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
